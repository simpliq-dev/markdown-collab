{
  "name": "codex-collab",
  "displayName": "codex-collab",
  "description": "In-file threaded chat for Markdown.",
  "version": "0.0.3",
  "publisher": "simpliq",
  "author": "Simpliq",
  "license": "MIT",
  "homepage": "https://marketplace.visualstudio.com/publishers/simpliq",
  "repository": {
    "type": "git",
    "url": "https://github.com/simpliq-dev/codex-collab.git"
  },
  "bugs": {
    "url": "https://github.com/simpliq-dev/codex-collab/issues"
  },
  "icon": "imgs/simpliq-icon-128.png",
  "keywords": [
    "markdown",
    "threads",
    "chat",
    "comments",
    "collaboration",
    "agent"
  ],
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#10151f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "activationEvents": [
    "onLanguage:markdown",
    "onView:codexCollab.threadsView",
    "onCommand:codexCollab.refreshThreads"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "codexCollab.threadsView",
          "name": "Threads",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codexCollab.refreshThreads",
        "title": "Codex Collab: Refresh Threads"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codexCollab.refreshThreads",
          "when": "view == codexCollab.threadsView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p .",
    "watch": "node ./node_modules/typescript/bin/tsc -w -p .",
    "vscode:prepublish": "npm run build",
    "package": "node ./node_modules/@vscode/vsce/vsce package",
    "publish": "node ./node_modules/@vscode/vsce/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.88.0",
    "@vscode/vsce": "^2.26.0",
    "typescript": "^5.3.3"
  }
}
